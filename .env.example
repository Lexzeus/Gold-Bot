# =============================================================================
# Gold (XAU/USD) Webhook Bot — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
# For production, prefer the ENCRYPTED route: put real secrets in `secrets.enc`
# (see scripts/encrypt_env.py) and only keep ENV_MASTER_KEY in the host's
# secret manager. The .env below is the dev-friendly fallback.
# =============================================================================

# --- Webhook auth -----------------------------------------------------------
# Shared HMAC secret. TradingView signs the raw body with this; we verify it.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
WEBHOOK_SIGNING_SECRET=replace_me_with_a_long_random_secret

# Optional simpler guard: a static token TradingView includes in the JSON.
# HMAC is the primary defense; this is belt-and-suspenders.
WEBHOOK_SHARED_TOKEN=replace_me_optional_token

# Reject alerts whose timestamp is older than this many seconds (replay guard).
WEBHOOK_MAX_AGE_SECONDS=120

# --- Encrypted secrets (production) -----------------------------------------
# Fernet key used to decrypt secrets.enc at startup. Keep OUT of the repo.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENV_MASTER_KEY=

# --- Discord relay ----------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy
# Optional SECOND webhook for lower-priority news flags. If set, news heads-ups
# and news-suppressed notices post here instead of the main signal channel.
DISCORD_NEWS_WEBHOOK_URL=

# --- News filter ------------------------------------------------------------
# Provider: "alphavantage" or "forexfactory" (FF needs no key, uses public JSON)
NEWS_PROVIDER=forexfactory
ALPHAVANTAGE_API_KEY=
# Minutes around a high-impact release during which signals are paused.
NEWS_BLACKOUT_MINUTES_BEFORE=30
NEWS_BLACKOUT_MINUTES_AFTER=30
# If true, BLOCK all signals when the news calendar can't be fetched (fail-safe).
# If false (default), proceed but flag the alert "news state unknown".
NEWS_FAIL_CLOSED=false

# --- Strategy config --------------------------------------------------------
SYMBOL=XAUUSD
HTF_LOOKBACK_BARS=500
# How many of the 4 higher timeframes (30m/1h/4h/1D) must agree with the
# trigger direction. 2 = looser/more alerts, 3 = balanced (default), 4 = strict.
HTF_REQUIRED_AGREEMENT=3
# Max acceptable spread in USD before a signal is suppressed (Gold).
MAX_SPREAD_USD=0.50
# Mute execution triggers outside the New York session volume pocket.
NY_SESSION_ONLY=true
NY_SESSION_START=08:00
NY_SESSION_END=12:00
TIMEZONE=America/New_York
